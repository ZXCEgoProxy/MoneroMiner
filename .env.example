# Environment Variables for MoneroMiner
# Copy this to .env and fill in your values

# Required: Your Monero wallet address
WALLET_ADDRESS=your_monero_wallet_address_here

# Pool configuration
POOL_ADDRESS=xmr-us-east1.nanopool.org
POOL_PORT=10300

# Worker name (optional, defaults to hostname)
WORKER_NAME=railway-miner

# Pool password (optional, defaults to 'x')
PASSWORD=x

# Number of mining threads (adjust based on Railway instance resources)
THREADS=1